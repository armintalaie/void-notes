{
  "manifest_version": 3,
  "name": "Void Note",
  "description": "Capture web snippets into rich notes in the Void Note side panel.",
  "version": "0.1.0",
  "minimum_chrome_version": "114",
  "permissions": [
    "sidePanel",
    "storage",
    "contextMenus",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Void Note",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "side_panel": {
    "default_path": "dist/chrome-extension/sidepanel.html"
  }
}
